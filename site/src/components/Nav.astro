---
interface Props {
  active?: 'home' | 'setup' | 'tools' | 'faq' | 'contribute';
}

const { active } = Astro.props;
const base = import.meta.env.BASE_URL;

const withBase = (path: string) => {
  const cleanPath = path.startsWith('/') ? path : `/${path}`;
  return `${base}${cleanPath}`;
};

const links = [
  { href: '/', label: 'Home', id: 'home' },
  { href: '/setup', label: 'Setup', id: 'setup' },
  { href: '/tools', label: 'Tools', id: 'tools' },
  { href: '/faq', label: 'FAQ', id: 'faq' },
  { href: '/contribute', label: 'Contribute', id: 'contribute' },
] as const;
---

<nav class="sticky top-0 z-50 border-b border-white/[0.06] bg-surface-0/95 backdrop-blur-md">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="flex items-center justify-between h-16">
      <a href={withBase('/')} class="flex items-center gap-2.5">
        <img src={withBase('/icon.svg')} alt="Home Assistant MCP" class="h-8 w-8" />
        <span class="font-display font-semibold text-white text-lg hidden sm:inline tracking-tight">ha-mcp</span>
      </a>
      <div class="flex items-center gap-1">
        {links.map(link => (
          <a
            href={withBase(link.href)}
            class:list={[
              'px-3 py-1.5 rounded-lg text-sm transition-colors',
              active === link.id
                ? 'text-brand font-medium bg-brand/[0.08]'
                : 'text-[var(--text-secondary)] hover:text-white hover:bg-white/[0.04]',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>
