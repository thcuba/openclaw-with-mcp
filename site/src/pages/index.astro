---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PlatformIcon from '../components/PlatformIcon.astro';

const base = import.meta.env.BASE_URL;

const withBase = (path: string) => {
  const cleanPath = path.startsWith('/') ? path : `/${path}`;
  return `${base}${cleanPath}`;
};
---

<Layout title="Home Assistant MCP Server">
  <Nav active="home" />

  <div class="container mx-auto px-4 max-w-5xl">

    <!-- Hero -->
    <header class="pt-20 pb-16 md:pt-28 md:pb-20 text-center fade-up">
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 tracking-tight leading-[1.1]">
        Home Assistant<br />
        <span class="text-brand">MCP Server</span>
      </h1>
      <p class="text-lg md:text-xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-10 leading-relaxed">
        A Model Context Protocol server that enables AI assistants to interact with Home Assistant.
        Control devices, query states, manage automations, and configure dashboards using natural language.
      </p>
      <div class="flex flex-wrap justify-center gap-4 fade-up fade-up-delay-1">
        <a href={withBase('/setup')} class="px-7 py-3 bg-brand hover:bg-brand-light text-surface-0 font-semibold rounded-xl transition-colors brand-glow">
          Get Started
        </a>
        <a href="https://github.com/homeassistant-ai/ha-mcp" class="px-7 py-3 bg-white/[0.05] hover:bg-white/[0.08] text-white font-semibold rounded-xl border border-white/[0.08] transition-colors">
          View on GitHub
        </a>
      </div>
    </header>

    <!-- Demo -->
    <div class="mb-24 max-w-4xl mx-auto fade-up fade-up-delay-2">
      <div class="rounded-2xl overflow-hidden border border-white/[0.06] shadow-2xl shadow-black/40">
        <img src="https://raw.githubusercontent.com/homeassistant-ai/ha-mcp/master/docs/img/demo.webp" alt="Demo with Claude Desktop" class="w-full" loading="lazy" />
      </div>
    </div>

    <!-- Quick Start -->
    <section class="mb-24 fade-up">
      <div class="text-center mb-10">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Quick Start</h2>
        <p class="text-[var(--text-secondary)]">No paid subscription required. Copy-paste one command to install.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-5 max-w-4xl mx-auto">
        <!-- macOS -->
        <div class="glass-card rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-white/[0.05] flex items-center justify-center">
              <PlatformIcon icon="apple" size={20} class="text-[var(--text-secondary)]" />
            </div>
            <div>
              <h3 class="font-display font-semibold text-white text-lg">macOS</h3>
              <p class="text-sm text-[var(--text-muted)]">Terminal</p>
            </div>
          </div>
          <ol class="text-[var(--text-secondary)] space-y-3 text-sm mb-5">
            <li class="flex gap-2"><span class="text-[var(--text-muted)] tabular-nums">1.</span> Sign in to <a href="https://claude.ai" class="text-brand hover:underline">claude.ai</a></li>
            <li class="flex gap-2"><span class="text-[var(--text-muted)] tabular-nums">2.</span> Run in Terminal:</li>
          </ol>
          <pre class="bg-surface-0 p-3.5 rounded-xl text-sm overflow-x-auto mb-5 border border-white/[0.04]"><code class="text-brand">curl -LsSf https://raw.githubusercontent.com/homeassistant-ai/ha-mcp/master/scripts/install-macos.sh | sh</code></pre>
          <ol class="text-[var(--text-secondary)] space-y-2 text-sm" start="3">
            <li class="flex gap-2"><span class="text-[var(--text-muted)] tabular-nums">3.</span> <a href="https://claude.ai/download" class="text-brand hover:underline">Download Claude Desktop</a></li>
            <li class="flex gap-2"><span class="text-[var(--text-muted)] tabular-nums">4.</span> Ask Claude: <em class="text-white/70">"Can you see my Home Assistant?"</em></li>
          </ol>
        </div>

        <!-- Windows -->
        <div class="glass-card rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-white/[0.05] flex items-center justify-center">
              <PlatformIcon icon="windows" size={20} class="text-[var(--text-secondary)]" />
            </div>
            <div>
              <h3 class="font-display font-semibold text-white text-lg">Windows</h3>
              <p class="text-sm text-[var(--text-muted)]">PowerShell</p>
            </div>
          </div>
          <ol class="text-[var(--text-secondary)] space-y-3 text-sm mb-5">
            <li class="flex gap-2"><span class="text-[var(--text-muted)] tabular-nums">1.</span> Sign in to <a href="https://claude.ai" class="text-brand hover:underline">claude.ai</a></li>
            <li class="flex gap-2"><span class="text-[var(--text-muted)] tabular-nums">2.</span> Run in PowerShell:</li>
          </ol>
          <pre class="bg-surface-0 p-3.5 rounded-xl text-sm overflow-x-auto mb-5 border border-white/[0.04]"><code class="text-brand">irm https://raw.githubusercontent.com/homeassistant-ai/ha-mcp/master/scripts/install-windows.ps1 | iex</code></pre>
          <ol class="text-[var(--text-secondary)] space-y-2 text-sm" start="3">
            <li class="flex gap-2"><span class="text-[var(--text-muted)] tabular-nums">3.</span> <a href="https://claude.ai/download" class="text-brand hover:underline">Download Claude Desktop</a></li>
            <li class="flex gap-2"><span class="text-[var(--text-muted)] tabular-nums">4.</span> Ask Claude: <em class="text-white/70">"Can you see my Home Assistant?"</em></li>
          </ol>
        </div>
      </div>

      <p class="text-center mt-6 text-[var(--text-muted)] text-sm">
        Need more options? <a href={withBase('/setup')} class="text-brand hover:underline">Use the Setup Wizard</a>
      </p>
    </section>

    <!-- Examples -->
    <section class="mb-24">
      <div class="text-center mb-10">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">What Can You Do With It?</h2>
        <p class="text-[var(--text-secondary)]">Just talk to your AI assistant naturally. Here are some examples:</p>
      </div>

      <div class="grid md:grid-cols-2 gap-4 max-w-4xl mx-auto">
        {[
          { prompt: "Create an automation that turns on the porch light at sunset", desc: "Creates the automation with proper triggers and actions" },
          { prompt: "Add a weather card to my dashboard", desc: "Updates your Lovelace dashboard with the new card" },
          { prompt: "The motion sensor automation isn't working, debug it", desc: "Analyzes execution traces, identifies the issue, suggests fixes" },
          { prompt: "Create a script that sets movie mode: dim lights, close blinds, turn on TV", desc: "Creates a reusable script with the sequence of actions" },
        ].map(({ prompt, desc }) => (
          <div class="glass-card rounded-xl p-5 group">
            <p class="text-white font-medium mb-2 leading-snug">"{prompt}"</p>
            <p class="text-[var(--text-muted)] text-sm">{desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Features -->
    <section class="mb-24">
      <div class="text-center mb-10">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Features</h2>
        <p class="text-[var(--text-secondary)]">92+ tools across 6 categories.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
        {([
          { title: "Search", desc: "Fuzzy entity search, deep config search, full system overview", icon: "search" as const },
          { title: "Control", desc: "Any service call, bulk device operations, real-time state tracking", icon: "zap" as const },
          { title: "Manage", desc: "Automations, scripts, helpers, dashboards, areas, zones, groups", icon: "grid" as const },
          { title: "Monitor", desc: "History, statistics, camera snapshots, automation traces", icon: "trending-up" as const },
          { title: "System", desc: "Backup and restore, updates, add-ons, device registry", icon: "settings" as const },
          { title: "Flexible", desc: "Works with Claude, ChatGPT, Cursor, Copilot, and 15+ AI clients", icon: "link" as const },
        ]).map(({ title, desc, icon }) => (
          <div class="glass-card rounded-xl p-5">
            <div class="w-9 h-9 rounded-lg bg-brand/[0.08] flex items-center justify-center mb-4">
              <PlatformIcon icon={icon} size={18} class="text-brand" />
            </div>
            <h3 class="font-display font-semibold text-white mb-1.5">{title}</h3>
            <p class="text-[var(--text-muted)] text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="mb-20">
      <div class="text-center rounded-2xl p-12 md:p-16 glass-card relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-brand/[0.04] to-transparent pointer-events-none"></div>
        <div class="relative">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4 tracking-tight">Ready to Get Started?</h2>
          <p class="text-[var(--text-secondary)] mb-8 max-w-md mx-auto">Set up ha-mcp with your AI assistant in minutes.</p>
          <a href={withBase('/setup')} class="inline-block px-8 py-3.5 bg-brand hover:bg-brand-light text-surface-0 font-semibold rounded-xl transition-colors brand-glow">
            Open Setup Wizard
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="pb-12 text-center text-sm border-t border-white/[0.06] pt-8">
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mb-4">
        <a href="https://github.com/homeassistant-ai/ha-mcp" class="text-[var(--text-muted)] hover:text-white transition-colors">GitHub</a>
        <a href="https://github.com/homeassistant-ai/ha-mcp/issues" class="text-[var(--text-muted)] hover:text-white transition-colors">Issues</a>
        <a href={withBase('/tools')} class="text-[var(--text-muted)] hover:text-white transition-colors">Tools</a>
        <a href={withBase('/faq')} class="text-[var(--text-muted)] hover:text-white transition-colors">FAQ</a>
        <a href={withBase('/contribute')} class="text-[var(--text-muted)] hover:text-white transition-colors">Contribute</a>
      </div>
      <div class="flex flex-wrap justify-center gap-2 mb-4">
        <img src="https://img.shields.io/github/v/release/homeassistant-ai/ha-mcp" alt="Release" class="h-5" loading="lazy" />
        <img src="https://img.shields.io/github/actions/workflow/status/homeassistant-ai/ha-mcp/e2e-tests.yml?branch=master&label=E2E%20Tests" alt="E2E Tests" class="h-5" loading="lazy" />
        <img src="https://img.shields.io/github/license/homeassistant-ai/ha-mcp.svg" alt="License" class="h-5" loading="lazy" />
      </div>
      <p class="text-[var(--text-muted)]">Built with FastMCP · <a href={withBase('/LICENSES-THIRD-PARTY.md')} class="hover:text-white transition-colors">Third-party licenses</a></p>
    </footer>
  </div>
</Layout>
